{
  "name": "eerzho/opentelemetry-auto-class-laravel",
  "description": "OpenTelemetry auto-instrumentation for PHP class methods (Laravel integration)",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "php",
    "otel",
    "opentelemetry",
    "trace",
    "tracing",
    "instrumentation",
    "auto-instrumentation",
    "package",
    "laravel",
    "laravel-package"
  ],
  "authors": [
    {
      "name": "Zhanbolat Yerkinbay",
      "email": "eerzho@gmail.com"
    }
  ],
  "require": {
    "php": ">=8.2",
    "ext-opentelemetry": "*",
    "open-telemetry/api": "^1.0",
    "eerzho/opentelemetry-auto-class": "^0.1",
    "illuminate/support": "^11.0 || ^12.0 || ^13.0"
  },
  "autoload": {
    "psr-4": {
      "OpenTelemetry\\Contrib\\Instrumentation\\Class\\Laravel\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "OpenTelemetry\\Contrib\\Instrumentation\\Class\\Laravel\\TraceableServiceProvider"
      ]
    }
  },
  "version": "0.1.0",
  "config": {
    "sort-packages": true
  }
}
