{
  "name": "eerzho/opentelemetry-auto-class-laravel",
  "description": "Laravel integration for automatic OpenTelemetry tracing via the #[Trace] attribute",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "opentelemetry",
    "otel",
    "telemetry",
    "tracing",
    "traces",
    "distributed-tracing",
    "instrumentation",
    "auto-instrumentation",
    "observability",
    "apm",
    "monitoring",
    "php-attributes",
    "spans",
    "laravel",
    "laravel-package"
  ],
  "authors": [
    {
      "name": "Zhanbolat Yerkinbay",
      "email": "eerzho@gmail.com"
    }
  ],
  "require": {
    "php": ">=8.2",
    "ext-opentelemetry": "*",
    "open-telemetry/api": "^1.0",
    "eerzho/opentelemetry-auto-class": "^0.1",
    "illuminate/support": "^11.0 || ^12.0 || ^13.0"
  },
  "autoload": {
    "psr-4": {
      "Eerzho\\Instrumentation\\Class\\Laravel\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Eerzho\\Instrumentation\\Class\\Laravel\\AutoClassServiceProvider"
      ]
    }
  },
  "config": {
    "sort-packages": true
  }
}
